{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Aerospike": {
    "Host": "localhost",
    "Port": 3000,
    "Namespace": "nsPseudoMarkets",
    "QuoteSetName": "sMarketQuotes",
    "DetailedQuoteSetName": "sDetailedMarketQuotes",
    "IndicesSetName": "sMarketIndices"
  },
  "TwelveData": {
    "BaseUrl": "https://api.twelvedata.com",
    "ApiKey": "YOUR_TWELVE_DATA_API_KEY"
  },
  "MarketDataCache": {
    "QuoteTtlSeconds": 15,
    "DetailedQuoteTtlSeconds": 60,
    "IndicesTtlSeconds": 60
  }
}
